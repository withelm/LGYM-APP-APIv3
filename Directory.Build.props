<Project>

  <!--
    Centralized nullable/warnings policy for LGYM API solution.
    See: .sisyphus/plans/issue-230-nullability-hardening.md
    
    Phase 1: Apply strict nullable warnings-as-errors to selected production projects only.
    Conservative first phase gates only projects with zero existing violations.
    Remaining production projects (Api, Application, Infrastructure, BackgroundWorker) 
    will be added after violations are fixed in subsequent tasks.
    
    EXPLICIT EXCLUSIONS from strict nullable warnings-as-errors escalation:
    
    1. Test projects (intentionally excluded from Phase 1 strict gating):
       - LgymApi.UnitTests
       - LgymApi.IntegrationTests
       - LgymApi.ArchitectureTests
       - LgymApi.DataSeeder.Tests
       - LgymApi.TestUtils
       Rationale: Test project nullable compliance will be addressed after production code baseline.
    
    2. EF Core generated migration artifacts (automatically excluded via #nullable disable):
       - LgymApi.Infrastructure/Migrations/**/*.Designer.cs (37 files)
       - LgymApi.Infrastructure/Migrations/AppDbContextModelSnapshot.cs
       Rationale: EF Core tooling emits `#nullable disable` directive at file top; no MSBuild exclusion needed.
       These files are regenerated by EF migrations and should not be manually modified.
    
    3. Utility/seeder projects (deferred):
       - LgymApi.DataSeeder
       - LgymApi.Resources
       Rationale: Non-critical to production runtime; addressed in later phases.
    
    Rollout: Remaining projects will be added incrementally after baseline is proven stable.
  -->

  <PropertyGroup>
    <!-- Define the set of gated production projects (Phase 1 - conservative baseline) -->
    <!-- Only projects with zero existing nullable violations are gated in Phase 1 -->
    <IsGatedProductionProject Condition="'$(MSBuildProjectName)' == 'LgymApi.Domain'">true</IsGatedProductionProject>
    <IsGatedProductionProject Condition="'$(MSBuildProjectName)' == 'LgymApi.BackgroundWorker.Common'">true</IsGatedProductionProject>

    <!-- Explicitly mark test projects as non-gated for clarity and future reference -->
    <IsTestProject Condition="'$(MSBuildProjectName)' == 'LgymApi.UnitTests' Or '$(MSBuildProjectName)' == 'LgymApi.IntegrationTests' Or '$(MSBuildProjectName)' == 'LgymApi.ArchitectureTests' Or '$(MSBuildProjectName)' == 'LgymApi.DataSeeder.Tests' Or '$(MSBuildProjectName)' == 'LgymApi.TestUtils'">true</IsTestProject>
  </PropertyGroup>

  <PropertyGroup Condition="'$(IsGatedProductionProject)' == 'true'">
    <!--
      Escalate nullable-related warnings to errors for gated projects.
      Comprehensive list of nullable reference type warnings (CS8600-CS8999 range).
      
      This policy prevents new nullable violations from being introduced.
      
      Generated migration files (*.Designer.cs, AppDbContextModelSnapshot.cs) are automatically
      excluded via #nullable disable directives emitted by EF Core tooling.
      Test projects are explicitly excluded via IsTestProject condition above.
    -->
    <WarningsAsErrors>$(WarningsAsErrors);CS8600;CS8601;CS8602;CS8603;CS8604;CS8605;CS8606;CS8607;CS8608;CS8609;CS8610;CS8611;CS8612;CS8613;CS8614;CS8615;CS8616;CS8617;CS8618;CS8619;CS8620;CS8621;CS8622;CS8623;CS8624;CS8625;CS8626;CS8627;CS8628;CS8629;CS8630;CS8631;CS8632;CS8633;CS8634;CS8635;CS8636;CS8637;CS8638;CS8639;CS8640;CS8641;CS8642;CS8643;CS8644;CS8645;CS8646;CS8647;CS8648;CS8649;CS8650;CS8651;CS8652;CS8653;CS8654;CS8655;CS8656;CS8657;CS8658;CS8659;CS8660;CS8661;CS8662;CS8663;CS8664;CS8665;CS8666;CS8667;CS8668;CS8669;CS8670;CS8671;CS8672;CS8673;CS8674;CS8675;CS8676;CS8677;CS8678;CS8679;CS8680;CS8681;CS8682;CS8683;CS8684;CS8685;CS8686;CS8687;CS8688;CS8689;CS8690;CS8691;CS8692;CS8693;CS8694;CS8695;CS8696;CS8697;CS8698;CS8699</WarningsAsErrors>
  </PropertyGroup>

</Project>
